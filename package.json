{
  "name": "@ax-compass/root",
  "version": "0.1.0",
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/bun": "^1.3.13",
    "@types/node": "latest",
    "typescript": "^6.0.3"
  },
  "catalog": {
    "@types/bun": "^1.3.13"
  },
  "keywords": ["ax", "ai-governance", "open-data", "typescript", "bun"],
  "license": "MIT",
  "private": true,
  "scripts": {
    "scraper": "bun run --cwd packages/scraper start",
    "build:data": "bun run scraper",
    "frontend:dev": "bun run --cwd apps/frontend dev",
    "frontend:build": "bun run --cwd apps/frontend build",
    "dev": "bun run frontend:dev",
    "build": "bun run build:data && bun run frontend:build",
    "typecheck": "bun run --cwd packages/scraper typecheck && bun run --cwd apps/frontend typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "fmt": "biome format .",
    "fmt:fix": "biome format --write .",
    "serve": "bunx serve docs",
    "test": "bun test"
  },
  "type": "module",
  "workspaces": {
    "packages": ["packages/*", "apps/*"]
  }
}
